{
  "name": "japangolearn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean && git clean -xdf node_modules .turbo",
    "dev:web": "pnpm --filter @japangolearn/web dev",
    "dev:admin": "pnpm --filter @japangolearn/admin dev",
    "dev:mobile": "pnpm --filter @japangolearn/mobile dev",
    "build:web": "pnpm --filter @japangolearn/web build",
    "build:admin": "pnpm --filter @japangolearn/admin build",
    "build:web:cloudflare": "pnpm --filter @japangolearn/web build:cloudflare",
    "build:admin:cloudflare": "pnpm --filter @japangolearn/admin build:cloudflare",
    "check:mobile": "pnpm --filter @japangolearn/mobile typecheck",
    "check:expo": "pnpm --filter @japangolearn/mobile exec expo install --check",
    "release:web:preview": "pnpm --filter @japangolearn/web preview:cloudflare",
    "release:web:production": "pnpm --filter @japangolearn/web deploy:cloudflare",
    "release:admin:preview": "pnpm --filter @japangolearn/admin preview:cloudflare",
    "release:admin:production": "pnpm --filter @japangolearn/admin deploy:cloudflare",
    "release:mobile:preview": "pnpm --filter @japangolearn/mobile exec eas update --channel preview --environment preview",
    "release:mobile:production": "pnpm --filter @japangolearn/mobile exec eas update --channel production --environment production",
    "db:types": "node scripts/generate-supabase-types.js",
    "seed:kanji": "node supabase/seed/kanji/seed-kanji.js"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "supabase": "2.109.0",
    "turbo": "2.5.6",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.1"
  }
}
